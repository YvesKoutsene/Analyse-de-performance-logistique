# --- NexLogix Project GitIgnore ---

# Data Files (Comme spécifié dans le README)
# On ignore les données brutes car elles peuvent être volumineuses
data/*.csv
data/*.xlsx
data/*.json
data/*.parquet

# Power BI 
# On AUTORISE les .pbix pour ce projet portfolio (pour que le travail soit visible)
# Mais on ignore les fichiers temporaires de récupération
*.tmp
*.copy
*.zip

# SQL
# On ne met jamais de fichiers de dump ou de logs SQL
*.sql.gz
*.sql.bak
*.log

# OS & IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Python & Environnement
__pycache__/
*.pyc
.env
.venv/
venv/
env/
dist/
build/
